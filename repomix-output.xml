### 4.2 `PhysicsState`пјҲ`CharacterPhysicsSystem.hpp`пјү

зҙ”иіҮж–ҷзөҗж§ӢпјҲPOD-likeпјүпјҢз„Ўж–№жі•пјҢз„Ўз№јжүҝгҖӮ

```cpp
struct PhysicsState {
    float velocityY;       // еһӮзӣҙйҖҹеәҰ
    float lastDeltaX;      // дёҠе№Җж°ҙе№ідҪҚз§»пјҲж”ңеё¶иЁҲз®—з”Ёпјү
    int   supportIndex;    // з«ҷеңЁе“Әйҡ»и§’иүІдёҠпјҲ-1 = з„Ўпјү
    int   moveDir;         // ијёе…Ҙж–№еҗ‘пјҲ-1/0/+1пјү
    bool  grounded;        // жҳҜеҗҰжҺҘең°
    bool  prevGrounded;    // дёҠе№ҖжҺҘең°зӢҖж…ӢпјҲиҗҪең°еҒөжё¬пјү
    bool  beingStoodOn;    // жңүдәәиё©еңЁиҮӘе·ұй ӯдёҠпјҲдёӢе№Җи·іиәҚеҲӨж–·з”Ёпјү
};
```

