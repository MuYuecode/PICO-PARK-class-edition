// ─────────────────────────────────────────────────────────────────────────────
void PhysicsWorld::StepPhysicsUpdate() {
    for (auto& wp : m_Bodies) {
        auto sp = wp.lock();
        if (sp && sp->IsActive()) {
            sp->PhysicsUpdate();
        }
    }
}

