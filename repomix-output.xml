    shared_ptr<Character>  Floor;       // ең°жқҝ
    shared_ptr<BGMPlayer>  BGMPlayer;   // иғҢжҷҜйҹіжЁӮж’ӯж”ҫеҷЁ
    shared_ptr<Character>  Header;      // жЁҷйЎҢ Logo
    shared_ptr<Character>  Door;        // й–ҖпјҲopen/close е…©зЁ®ең–зүҮпјҢLocalPlayGameScene еҲҮжҸӣпјү

    // в”Җв”Җ жЁҷйЎҢз•«йқўзҡ„ 8 йҡ»иЈқйЈҫиІ“пјҲд№ҹжҳҜйҒҠжҲІдёӯеҸҜж“ҚжҺ§зҡ„и§’иүІпјүв”Җв”Җ
