    // TODO еҜҰдҪңжҷӮиЈңе……пјҡ
    //   - иЁҲз®—зӣ®еүҚи·қйӣў d = distance(A.pos, B.pos)
    //   - иӢҘ d <= maxLenпјҢдёҚж–ҪеҠӣ
    //   - иӢҘ d >  maxLenпјҡ
    //       dir = normalize(A.pos - B.pos)   // еҫһ B жҢҮеҗ‘ A
    //       еҠӣеӨ§е°Ҹ = (d - maxLen) * stiffness
    //       A.velocity -= dir * еҠӣ * (1 - friction)
    //       B.velocity += dir * еҠӣ * (1 - friction)
};

// PhysicsWorldпјҡзү©зҗҶзү©д»¶зҡ„еҚ”иӘҝиҖ…
//
// иҒ·иІ¬пјҡ
//   1. жҢҒжңүе ҙжҷҜдёӯжүҖжңү IPhysicsBody зҡ„ејұеј•з”Ё(дёҚж“Ғжңүз”ҹе‘ҪйҖұжңҹ)
//   2. жҜҸ frame жҢүй ҶеәҸеҹ·иЎҢпјҡ
//       a. е‘јеҸ«еҗ„ body зҡ„ PhysicsUpdate()(иҮӘй©…еӢ•йӮҸијҜ)
//       b. и§Јжһҗз№©зҙўзҙ„жқҹ
//       c. е»Јж’ӯ AABB зў°ж’һдәӢд»¶(е‘јеҸ« OnCollision)
//   3. жҸҗдҫӣжҹҘи©ўе·Ҙе…·пјҢдҫӣеҗ„ System дҪҝз”Ё(иЁҲз®—гҖҢжңүе№ҫдәәжҺЁз®ұеӯҗгҖҚзӯү)
//
// дёҚиІ иІ¬зҡ„дәӢпјҡ
//   - зҺ©е®¶ијёе…Ҙ(Scene зҡ„иІ¬д»»)
//   - еӢ•з•«еҲҮжҸӣ(еҗ„зү©д»¶иҮӘиЎҢиҷ•зҗҶ)
//   - жёІжҹ“(GameObject / Renderer зҡ„иІ¬д»»)
class PhysicsWorld {
public:
    PhysicsWorld()  = default;
    ~PhysicsWorld() = default;

    PhysicsWorld(const PhysicsWorld&)            = delete;
    PhysicsWorld& operator=(const PhysicsWorld&) = delete;

    // зҷ»иЁҳ / з§»йҷӨ
    void Register(const std::shared_ptr<IPhysicsBody>& body);
    void Unregister(const IPhysicsBody* body);
    void Clear();

    // з№©зҙў
    void AddRope(IPhysicsBody* a, IPhysicsBody* b,
                 float maxLen = 200.0f, float friction = 0.5f);
    void RemoveRope(IPhysicsBody* a, IPhysicsBody* b);

    // дё»иҰҒжӣҙж–°(жҜҸ frame з”ұ Scene е‘јеҸ«дёҖж¬Ў)
    void Update();

    // жҹҘи©ўе·Ҙе…·(дҫӣеҗ„ System / зү©д»¶зҡ„ PhysicsUpdate дҪҝз”Ё)

    // иЁҲз®—гҖҢжңүе№ҫеҖӢ CHARACTER body жӯЈеңЁеҫҖ dir ж–№еҗ‘жҺЁ targetгҖҚ
    // dir: +1 = еҗ‘еҸіжҺЁ(body еңЁ target е·ҰеҒҙеҫҖеҸіз§»)пјҢ-1 = еҗ‘е·ҰжҺЁ
    // з”Ёж–јпјҡPushableBox еҲӨж–·жҳҜеҗҰйҒ”еҲ° n дәәжҺЁеӢ•жўқд»¶
    // int CountCharactersPushing(const IPhysicsBody* target, int dir) const;

    // иЁҲз®—гҖҢжңүе№ҫеҖӢ body з«ҷеңЁ target й ӮйғЁгҖҚ
    // з”Ёж–јпјҡConditionalPlatform еҲӨж–·жҳҜеҗҰйҒ”еҲ° n дәәз«ҷдёҠжўқд»¶
    // int CountBodiesOnTop(const IPhysicsBody* target) const;

    // еӣһеӮіжүҖжңүиҲҮ target зҡ„ AABB жңүйҮҚз–Ҡзҡ„ body
    // з”Ёж–јпјҡBullet зў°ж’һеҒөжё¬гҖҒж•өдәәеӮ·е®ізҜ„еңҚ
    // std::vector<IPhysicsBody*> QueryOverlapping(const IPhysicsBody* target) const;

    // еӣһеӮіжүҖжңүжҢҮе®ҡйЎһеһӢзҡ„ body
    [[nodiscard]] std::vector<IPhysicsBody*> GetBodiesOfType(BodyType type) const;

    // еҸ–еҫ—иҲҮжҢҮе®ҡ body йҖЈзөҗзҡ„жүҖжңүз№©зҙў
    std::vector<RopeConstraint*> GetRopesOf(const IPhysicsBody* body);

private:
    // е·Ҙе…·
    static bool AabbOverlaps(const IPhysicsBody* a, const IPhysicsBody* b) ;
    // bool IsOnTop(const IPhysicsBody* rider, const IPhysicsBody* platform) const;

    // жё…зҗҶе·ІеӨұж•Ҳзҡ„ејұеј•з”Ё(жҜҸ N frame еҹ·иЎҢдёҖж¬Ў)
    void PurgeExpired();

    // е…§йғЁжӣҙж–°жӯҘй©ҹ
    void StepPhysicsUpdate() const ;   // е‘јеҸ«жүҖжңү body зҡ„ PhysicsUpdate()
    // void StepRopes();           // и§Јжһҗз№©зҙўзҙ„жқҹ
    // void StepCollisions();      // е»Јж’ӯ AABB зў°ж’һдәӢд»¶

    // иіҮж–ҷ
    std::vector<std::weak_ptr<IPhysicsBody>> m_Bodies;
    std::vector<RopeConstraint>              m_Ropes;

    int m_FrameCount = 0;
    static constexpr int kPurgeInterval = 60;  // жҜҸ 60 frame жё…зҗҶдёҖж¬ЎеӨұж•Ҳеј•з”Ё
};

#endif // PHYSICS_WORLD_HPP
</file>

