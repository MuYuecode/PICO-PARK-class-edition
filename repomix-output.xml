    m_MenuFrame->SetScale({408.0f / 695.0f, 287.0f / 218.0f});
    m_ExitGameButton->SetPosition({188.0f, 15.5f});

    m_IsYesSelected = true;
    UpdateChoiceFramePosition();
}

