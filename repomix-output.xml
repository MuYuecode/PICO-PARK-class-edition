<file path="IPhysicsBody.hpp">
//
// Created by cody2 on 2026/3/19.
//
#ifndef PHYSICS_BODY_HPP
#define PHYSICS_BODY_HPP

#include "pch.hpp"

class IPhysicsBody;

// зү©зҗҶзү©д»¶йЎһеһӢ
enum class BodyType {
    CHARACTER,              // зҺ©е®¶и§’иүІ(PlayerCat)
    PUSHABLE_BOX,           // жңүжўқд»¶еҸҜиў«жҺЁеӢ•зҡ„з®ұеӯҗ
    PATROL_ENEMY,           // еӣәе®ҡе·ЎйӮҸи·Ҝеҫ‘зҡ„ж•өдәә
    MOVING_PLATFORM,        // еӣәе®ҡи»Ңи·Ўз§»еӢ•зҡ„е№іеҸ°
    CONDITIONAL_PLATFORM,   // жңүжўқд»¶жүҚз§»еӢ•зҡ„е№іеҸ°
    ROPE_ENDPOINT,          // з№©зҙўз«Ҝй»һ(жҲҗе°ҚеҮәзҸҫ)
    BULLET,                 // еӯҗеҪҲ
};

// зў°ж’һиіҮиЁҠ(еӮіе…Ҙ OnCollision зҡ„е®Ңж•ҙжғ…еўғ)
struct CollisionInfo {
    IPhysicsBody* other    = nullptr;      // зў°еҲ°иӘ°
    glm::vec2     normal   = {0, 0};   // зў°ж’һжі•еҗ‘йҮҸ(еҫһ other жҢҮеҗ‘ self)
    float         depth    = 0.0f;         // з©ҝйҖҸж·ұеәҰ
};

// IPhysicsBodyпјҡжүҖжңүеҸҜеҸғиҲҮзү©зҗҶдә’еӢ•зҡ„зү©д»¶еҝ…й ҲеҜҰдҪңжӯӨд»Ӣйқў
// иЁӯиЁҲеҺҹеүҮпјҡ
//   - д»ӢйқўеҸӘе®ҡзҫ©гҖҢPhysicsWorld йңҖиҰҒзҹҘйҒ“зҡ„жңҖе°ҸиіҮиЁҠгҖҚ
//   - е…·й«”зҡ„еӢ•з•«гҖҒжёІжҹ“гҖҒAI йӮҸијҜз•ҷеңЁеӯҗйЎһеҲҘ
//   - PhysicsUpdate() жҳҜзү©д»¶зҡ„гҖҢиҮӘй©…еӢ•гҖҚйӮҸијҜ(ж•өдәәз§»еӢ•гҖҒе№іеҸ°и»Ңи·Ўзӯү)
//   - OnCollision()   жҳҜзү©д»¶е°ҚгҖҢеӨ–йғЁзў°ж’һдәӢд»¶гҖҚзҡ„еҸҚжҮү
class IPhysicsBody {
public:
    virtual ~IPhysicsBody() = default;

    // иә«еҲҶиӯҳеҲҘ
    [[nodiscard]] virtual BodyType GetBodyType() const = 0;

    // дҪҚзҪ®иҲҮе°әеҜё(AABB зў°ж’һеҹәзӨҺ)
    [[nodiscard]] virtual glm::vec2 GetPosition() const = 0;
    virtual void          SetPosition(const glm::vec2& pos) = 0;

    // еӣһеӮізў°ж’һз®ұеҚҠеҜ¬гҖҒеҚҠй«ҳ(дёҚдёҖе®ҡзӯүж–јең–зүҮеӨ§е°Ҹ)
    [[nodiscard]] virtual glm::vec2 GetHalfSize() const = 0;

    // йҖҹеәҰ
    [[nodiscard]] virtual glm::vec2 GetVelocity() const = 0;
    virtual void      SetVelocity(const glm::vec2& vel) = 0;

    // зү©зҗҶеұ¬жҖ§

    // жҳҜеҗҰзӮәеҜҰй«”(true = йҳ»ж“Ӣе…¶д»–зү©й«”з©ҝи¶ҠпјҢfalse = еҸҜз©ҝйҖҸпјҢеҰӮеӯҗеҪҲи§ёзҷјеҚҖ)
    [[nodiscard]] virtual bool IsSolid() const = 0;

    // жҳҜеҗҰз”ұеӨ–йғЁжҺ§еҲ¶дҪҚзҪ®(true = PhysicsWorld дёҚе°Қе…¶ж–ҪеҠ йҮҚеҠӣ/жҺЁеҠӣ)
    // е№іеҸ°гҖҒеӣәе®ҡж•өдәәи·Ҝеҫ‘зҡҶзӮә trueпјӣзҺ©е®¶гҖҒз®ұеӯҗзӮә false
    [[nodiscard]] virtual bool IsKinematic() const = 0;

    // жҳҜеҗҰеҸ—йҮҚеҠӣеҪұйҹҝ(и§’иүІ/з®ұеӯҗ=trueпјҢе№іеҸ°/еӯҗеҪҲ=false)
    [[nodiscard]] virtual bool UseGravity() const = 0;

    // з”ҹе‘ҪйҖұжңҹ
    // жҜҸ frame з”ұ PhysicsWorld е‘јеҸ«пјҢзү©д»¶еҸҜеңЁжӯӨжӣҙж–°иҮӘиә«зӢҖж…Ӣ
    // (ж•өдәә AIгҖҒе№іеҸ°и»Ңи·ЎиЁҲз®—гҖҒеӯҗеҪҲз§»еӢ•зӯү)
    // иӢҘйңҖжҹҘи©ўе…¶д»–зү©д»¶пјҢжҮүйҖҸйҒҺ PhysicsWorld зҡ„жҹҘи©ўе·Ҙе…·(CountCharactersPushing зӯү)пјҢиҖҢйқһзӣҙжҺҘеӯҳеҸ–е…¶д»– body зҡ„дҪҚзҪ®
    virtual void PhysicsUpdate() {}

    // зў°ж’һи§Јжһҗе®ҢжҲҗеҫҢпјҢPhysicsWorld йҖҡзҹҘжӯӨзү©д»¶иҲҮиӘ°зҷјз”ҹдәҶзў°ж’һ
    // еӯҗйЎһеҲҘеңЁйҖҷиЈЎеҜҰдҪңгҖҢзў°еҲ°зҺ©е®¶жүЈиЎҖгҖҚгҖҢзў°еҲ°еӯҗеҪҲж”№и®ҠзӢҖж…ӢгҖҚзӯүйӮҸијҜ
    virtual void OnCollision(const CollisionInfo& /*info*/) {}

    // е•ҹз”Ё / еҒңз”Ё
    [[nodiscard]] virtual bool IsActive() const { return m_Active; }
    virtual void SetActive(bool active) { m_Active = active; }

protected:
    bool m_Active = true;
};

#endif // PHYSICS_BODY_HPP
</file>

