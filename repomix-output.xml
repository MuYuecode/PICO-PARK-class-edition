    LOG_INFO("ExitConfirmScene::OnExit");

    m_Ctx.Root.RemoveChild(m_ExitGame1Text);
    m_Ctx.Root.RemoveChild(m_YesText);
    m_Ctx.Root.RemoveChild(m_NoText);
    m_Ctx.Root.RemoveChild(m_ChoiceFrame);

    m_MenuFrame->SetScale({1.0f, 1.0f});
