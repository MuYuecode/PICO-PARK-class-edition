public:
    PlayerCat(const CatAnimPaths& animPaths,
              Util::Keycode leftKey,
              Util::Keycode rightKey,
              Util::Keycode jumpKey);

    // еӢ•з•«зӢҖж…Ӣз®ЎзҗҶ
