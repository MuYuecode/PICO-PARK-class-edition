#ifndef PICOPART_SCENE_HPP
#define PICOPART_SCENE_HPP

#include "GameContext.hpp"

/**
 * @brief жүҖжңүе ҙжҷҜзҡ„жҠҪиұЎеҹәеә•йЎһеҲҘ
 *
 * з”ҹе‘ҪйҖұжңҹ
 *
 *   App::Start()    вҶ’ е»әз«ӢжүҖжңү Scene зү©д»¶(жӯӨжҷӮдёҚе‘јеҸ« OnEnter)
 *   TransitionTo(X) вҶ’ е…Ҳе‘јеҸ«еүҚдёҖеҖӢе ҙжҷҜзҡ„ OnExit()пјҢеҶҚе‘јеҸ« X зҡ„ OnEnter()
 *   жҜҸеҖӢ frame      вҶ’ Update() иў«е‘јеҸ«пјҢеӣһеӮідёӢдёҖеҖӢе ҙжҷҜзҡ„жҢҮжЁҷ
 *
 * Update() еӣһеӮіеҖјзҙ„е®ҡ
 *
 *   nullptr   вҶ’ з№јзәҢеҫ…еңЁйҖҷеҖӢе ҙжҷҜпјҢдёҚеҲҮжҸӣ
 *   Scene*    вҶ’ еҲҮжҸӣеҲ°и©Іе ҙжҷҜ(жҢҮжЁҷз”ұ App жҢҒжңүпјҢScene еҸӘеҖҹз”ЁпјҢдёҚиғҪ delete)
 *
 * AddChild / RemoveChild зҡ„дҪҝз”ЁиҰҸеүҮ
 *
 *   OnEnter() иЈЎе‘јеҸ« m_Ctx.Root.AddChild(xxx)   вҶ’ еҠ е…ҘжёІжҹ“жЁ№
 *   OnExit()  иЈЎе‘јеҸ« m_Ctx.Root.RemoveChild(xxx) вҶ’ еҫһжёІжҹ“жЁ№з§»йҷӨ
 *
 *   гҖҢдёҖе®ҡиҰҒй…Қе°ҚгҖҚпјҢеҗҰеүҮеҗҢдёҖеҖӢ shared_ptr жңғеңЁжёІжҹ“жё…е–®иЈЎеҮәзҸҫе…©ж¬ЎпјҢ
 *   йҖ жҲҗжҜҸж¬ЎйҖІе…Ҙе ҙжҷҜе°ұеӨҡжёІжҹ“дёҖеҖӢйҮҚз–Ҡзҡ„ең–еұӨ
 *
 * жүҖжңүж¬Ҡ
 *
 *   App д»Ҙ unique_ptr<Scene> жҢҒжңүжүҖжңүе ҙжҷҜ(иІ иІ¬з”ҹе‘ҪйҖұжңҹ)
 *   Scene д№Ӣй–“дә’еӮізҡ„жҳҜ raw pointer(non-owning)пјҢзө•е°ҚдёҚиғҪ delete
 */
class Scene {
public:
    explicit Scene(GameContext& ctx) : m_Ctx(ctx) {}

    virtual ~Scene() = default;

    // е ҙжҷҜдёҚжҮүиў«иӨҮиЈҪжҲ–з§»еӢ•
    Scene(const Scene&)            = delete;
    Scene& operator=(const Scene&) = delete;
    Scene(Scene&&)                 = delete;
    Scene& operator=(Scene&&)      = delete;

    // зҙ”иҷӣж“¬д»Ӣйқў
    /**
     * @brief йҖІе…ҘжӯӨе ҙжҷҜжҷӮе‘јеҸ«дёҖж¬Ў
     * - е‘јеҸ« m_Ctx.Root.AddChild() жҠҠйңҖиҰҒзҡ„зү©д»¶еҠ е…ҘжёІжҹ“жЁ№
     * - йҮҚзҪ®е ҙжҷҜе…§йғЁзӢҖж…Ӣ(иЁҲжҷӮеҷЁгҖҒйҒёж“Үзҙўеј•вҖҰ)
     */
    virtual void OnEnter() = 0;

    /**
     * @brief йӣўй–ӢжӯӨе ҙжҷҜжҷӮе‘јеҸ«дёҖж¬Ў
     * - е‘јеҸ« m_Ctx.Root.RemoveChild() з§»йҷӨжң¬е ҙжҷҜеҠ е…Ҙзҡ„зү©д»¶
     * - еҝ…й ҲиҲҮ OnEnter иЈЎзҡ„ AddChild е®Ңе…Ёй…Қе°Қ
     */
    virtual void OnExit()  = 0;

    /**
     * @brief жҜҸ frame е‘јеҸ«дёҖж¬Ў
     * @return nullptr з№јзәҢеҫ…еңЁжӯӨе ҙжҷҜпјӣе…¶д»–жҢҮжЁҷеҲҮжҸӣеҲ°и©Іе ҙжҷҜ
     */
    virtual Scene* Update() = 0;

protected:
    GameContext& m_Ctx;
};

#endif //PICOPART_SCENE_HPP
</file>

