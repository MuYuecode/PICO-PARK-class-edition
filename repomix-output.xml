// SaveManager.hpp
// иІ иІ¬и®ҖеҜ« GA_RESOURCE_DIR/Save/ дёӢзҡ„жҢҒд№…еҢ–иіҮж–ҷпјҡ
//   settings.json  вҖ” OptionMenuScene иЁӯе®ҡ + KeyboardConfigScene жҢүйҚөз¶Ғе®ҡ
//   save_data.json вҖ” еҗ„й—ңеҚЎйҖҡй—ңзӢҖж…ӢиҲҮжңҖдҪіжҷӮй–“зҙҖйҢ„
//
// дҪҝз”Ёж–№ејҸ(еҗ„е ҙжҷҜеҸӘйңҖ #include жӯӨжЁҷй ӯ)пјҡ
//
//   // е„Іеӯҳ Option иЁӯе®ҡ(еңЁ OptionMenuScene OK жҷӮе‘јеҸ«)
//   SaveManager::SaveOptionSettings(opts);
//
//   // е„ІеӯҳжҢүйҚөз¶Ғе®ҡ(еңЁ KeyboardConfigScene CommitPending жҷӮе‘јеҸ«)
//   SaveManager::SaveKeyConfigs(keysArray);
//
//   // жӣҙж–°е–®дёҖй—ңеҚЎжңҖдҪіжҷӮй–“(еңЁй—ңеҚЎе®ҢжҲҗжҷӮе‘јеҸ«)
//   SaveManager::UpdateBestTime(levelIdx, playerCount, elapsedSeconds);
//

#ifndef SAVE_MANAGER_HPP
#define SAVE_MANAGER_HPP

#include <string>
#include <array>

// Option иЁӯе®ҡиіҮж–ҷ
// е°ҚжҮү OptionMenuScene::SettingsпјҢдҪҶзҚЁз«Ӣе®ҡзҫ©д»ҘйҒҝе…ҚеҫӘз’°дҫқиіҙ
struct OptionSettingsData {
    int  bgColorIndex = 0;
    int  bgmVolume    = 10;
    int  seVolume     = 10;
    bool dispNumber   = false;
};

// жҢүйҚөз¶Ғе®ҡиіҮж–ҷ(д»Ҙ int е„ІеӯҳпјҢе°ҚжҮү Util::Keycode еә•еұӨеҖј)
// Util::Keycode::UNKNOWN = 0(SDL_SCANCODE_UNKNOWN)
struct KeyConfigData {
    int up      = 0;
    int down    = 0;
    int left    = 0;
    int right   = 0;
    int jump    = 0;
    int cancel  = 0;
    int shot    = 0;
    int menu    = 0;
    int subMenu = 0;
};

// е–®дёҖй—ңеҚЎеӯҳжӘ”
struct LevelSaveData {
    bool completed = false;
    // index 2~8 еҲҶеҲҘе°ҚжҮү 2P~8P зҡ„жңҖдҪіжҷӮй–“(з§’)пјӣ-1.0f иЎЁзӨәе°ҡжңӘз ҙй—ң
    std::array<float, 9> bestTimes;

    LevelSaveData() { bestTimes.fill(-1.0f); }
};

// SaveManager
class SaveManager {
public:
    static constexpr int MAX_PLAYERS = 8;
    static constexpr int LEVEL_COUNT = 10;

    // settings.json

    /**
     * е„Іеӯҳ Option иЁӯе®ҡ(иғҢжҷҜиүІгҖҒйҹійҮҸзӯү)
     * жҺЎз”Ё read-modify-writeпјҡдёҚжңғиҰҶи“Ӣ keyConfigs ж¬„дҪҚ
     */
    static bool SaveOptionSettings(const OptionSettingsData& opts);

    /**
     * и®ҖеҸ– Option иЁӯе®ҡ
     * иӢҘжӘ”жЎҲдёҚеӯҳеңЁжҲ–и§ЈжһҗеӨұж•—пјҢдҝқз•ҷ outOpts еҺҹжң¬зҡ„й җиЁӯеҖјдёҰеӣһеӮі false
     */
    static bool LoadOptionSettings(OptionSettingsData& outOpts);

    /**
     * е„Іеӯҳе…ЁйғЁ 8 дҪҚзҺ©е®¶зҡ„жҢүйҚөз¶Ғе®ҡ
     * жҺЎз”Ё read-modify-writeпјҡдёҚжңғиҰҶи“Ӣ option иЁӯе®ҡж¬„дҪҚ
     */
    static bool SaveKeyConfigs(
        const std::array<KeyConfigData, MAX_PLAYERS>& keys);

    /**
     * и®ҖеҸ–жҢүйҚөз¶Ғе®ҡ
     * иӢҘжӘ”жЎҲдёҚеӯҳеңЁжҲ–и§ЈжһҗеӨұж•—пјҢдҝқз•ҷ outKeys еҺҹжң¬зҡ„й җиЁӯеҖјдёҰеӣһеӮі false
     */
    static bool LoadKeyConfigs(
        std::array<KeyConfigData, MAX_PLAYERS>& outKeys);

    // save_data.json

    /**
     * е„Іеӯҳе…ЁйғЁй—ңеҚЎзҡ„йҖҡй—ңзӢҖж…ӢиҲҮжңҖдҪіжҷӮй–“
     */
    static bool SaveLevelData(
        const std::array<LevelSaveData, LEVEL_COUNT>& levels);

    /**
     * и®ҖеҸ–й—ңеҚЎеӯҳжӘ”
     * иӢҘжӘ”жЎҲдёҚеӯҳеңЁжҲ–и§ЈжһҗеӨұж•—пјҢдҝқз•ҷ outLevels еҺҹжң¬зҡ„й җиЁӯеҖјдёҰеӣһеӮі false
     */
    static bool LoadLevelData(
        std::array<LevelSaveData, LEVEL_COUNT>& outLevels);

    /**
     * дҫҝеҲ©еҮҪејҸпјҡжӣҙж–°е–®дёҖй—ңеҚЎзҡ„жңҖдҪіжҷӮй–“
     * еҸӘжңүз•¶ elapsed < зӣ®еүҚиЁҳйҢ„(жҲ–е°ҡз„ЎиЁҳйҢ„)жҷӮжүҚжӣҙж–°дёҰе„Іеӯҳ
     * @param levelIdx    0-indexed (0 = Level 1)
     * @param playerCount 2 ~ 8
     * @param elapsed     йҖҷж¬Ўз ҙй—ңиҖ—жҷӮ(з§’)
     * @return true иЎЁзӨәзўәеҜҰеҜ«е…ҘдәҶж–°зҙҖйҢ„
     */
    static bool UpdateBestTime(int levelIdx, int playerCount, float elapsed);

    // е·Ҙе…·

    /** ж јејҸеҢ–жҷӮй–“зӮә "mm:ss.cs"(mm=еҲҶ, ss=з§’, cs=зҷҫеҲҶз§’)пјӣ-1.0f вҶ’ "--:--.--" */
    static std::string FormatTime(float seconds);

    static std::string GetSettingsPath();
    static std::string GetSaveDataPath();
};

#endif // SAVE_MANAGER_HPP
</file>

