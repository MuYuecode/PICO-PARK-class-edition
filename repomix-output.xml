    // 借用的共用物件（從 MenuScene 拿到）
    m_Ctx.Root.AddChild(m_MenuFrame);
    m_Ctx.Root.AddChild(m_ExitGameButton);
    m_Ctx.Root.AddChild(m_LeftTriButton);
