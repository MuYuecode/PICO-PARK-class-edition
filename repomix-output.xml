<file path="AppStart.cpp">
#include "App.hpp"
#include "BGMPlayer.hpp"
#include "CatAssets.hpp"

#include "TitleScene.hpp"
#include "MenuScene.hpp"
#include "ExitConfirmScene.hpp"
#include "OptionMenuScene.hpp"
