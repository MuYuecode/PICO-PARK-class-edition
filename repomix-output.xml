    // в”Җв”Җ йҒҠжҲІеҹ·иЎҢжңҹиіҮж–ҷ в”Җв”Җ
    int  SelectedPlayerCount  = 2;
    int  CooperativePushPower = 1;
    bool ShouldQuit           = false;

    // и§’иүІйЎҸиүІй ҶеәҸпјҲindex 0вҖ“7 дҫқеәҸзӮә blue, red, yellow, green, purple, pink, orange, grayпјү
    static constexpr array<const char*, 8> kCatColorOrder = { ... };
