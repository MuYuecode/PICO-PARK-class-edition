#ifndef CHARACTER_PHYSICS_SYSTEM_HPP
#define CHARACTER_PHYSICS_SYSTEM_HPP

#include <memory>
#include <vector>

#include "PlayerCat.hpp"
#include "Character.hpp"

// PhysicsStateпјҡжҜҸйҡ»и§’иүІзҡ„зү©зҗҶзӢҖж…Ӣ(зҙ”иіҮж–ҷпјҢз”ұ Scene жҢҒжңү)
struct PhysicsState {
    float velocityY     = 0.0f;
    float lastDeltaX    = 0.0f;
    int   supportIndex  = -1;   // з«ҷеңЁе“Әйҡ»и§’иүІдёҠпјҡ-1 = з„Ў
    int   moveDir       = 0;    // -1 / 0 / +1
    bool  grounded      = true;
    bool  prevGrounded  = true; // еүҚдёҖе№ҖжҳҜеҗҰжҺҘең°(иҗҪең°еҒөжё¬з”Ё)
    bool  beingStoodOn  = false; // жңүе…¶д»–и§’иүІиё©еңЁиҮӘе·ұй ӯдёҠ
};

// PhysicsAgentпјҡactor + зү©зҗҶзӢҖж…Ӣжү“еҢ…жҲҗдёҖзө„(Scene жҢҒжңү vector<PhysicsAgent>)
struct PhysicsAgent {
    std::shared_ptr<PlayerCat> actor;
    PhysicsState               state;
};

// CharacterPhysicsSystemпјҡзҙ”з®—жі•пјҢз„ЎжҲҗе“ЎзӢҖж…Ӣ
// дҪҝз”Ёж–№ејҸ(Scene::Update дёӯ)пјҡ
//   m_Physics.Update(m_Agents, m_Ctx.Floor);
// еӢ•з•«зӢҖж…Ӣз”ұ System е…§йғЁзӣҙжҺҘе‘јеҸ« agent.actor->SetCatAnimState()пјҢ
// е ҙжҷҜе®Ңе…ЁдёҚйңҖиҰҒиҮӘиЎҢеҲӨж–·еӢ•з•«
class CharacterPhysicsSystem {
public:
    // зү©зҗҶеёёж•ё publicпјҢдҫӣ Scene йңҖиҰҒжҷӮи®ҖеҸ–
    static constexpr float kGroundMoveSpeed  = 5.0f;
    static constexpr float kRunOnPlayerSpeed = 6.2f;
    static constexpr float kJumpForce        = 11.0f;
    static constexpr float kGravity          = 0.75f;

    // з•«йқўйӮҠз•Ң(1280Г—720пјҢд»ҘеҺҹй»һзӮәдёӯеҝғ)
    static constexpr float kScreenHalfW = 640.0f;   // вҶҗ еҺҹжң¬жҺЁз®—йҢҜиӘӨзҡ„ 400.0f
    static constexpr float kScreenHalfH = 360.0f;   // вҶҗ еҺҹжң¬жҺЁз®—йҢҜиӘӨзҡ„ 300.0f

    static void ApplyJump(PhysicsState& state) {
        state.velocityY    = kJumpForce;
        state.grounded     = false;
        state.supportIndex = -1;
    }

    // дё»иҰҒжӣҙж–°д»Ӣйқў
    // жҜҸ frame е‘јеҸ«дёҖж¬Ўпјӣе…§йғЁдҫқеәҸиҷ•зҗҶпјҡ
    //   1. ж”ңеё¶(иў«иё©и§’иүІи·ҹйҡЁж”Ҝж’җиҖ…з§»еӢ•)
    //   2. ж°ҙе№із§»еӢ• + зў°ж’һи§Јжһҗ
    //   3. еһӮзӣҙзү©зҗҶ(йҮҚеҠӣ + ең°жқҝ + иё©й ӯ)
    //   4. еӢ•з•«зӢҖж…ӢеҲҮжҸӣ
    static void Update(std::vector<PhysicsAgent>& agents,
                const std::shared_ptr<Character>& floor) ;

    // е–®дёҖи§’иүІзҡ„ж°ҙе№ідҪҚз§»(дёҚеҗ«зү©зҗҶпјҢеҸӘз§»еӢ• + зў°ж’һйҷҗеҲ¶)
    // дҫӣйңҖиҰҒгҖҢеҸӘз§»еӢ•дёҖйҡ»гҖҚзҡ„е ҙжҷҜдҪҝз”Ё
    static float ResolveHorizontal(int idx,
                                          float targetX,
                                          const std::vector<PhysicsAgent>& agents) ;

private:
    // и§’иүІе°әеҜё(еҒҮиЁӯжүҖжңүи§’иүІе°әеҜёзӣёеҗҢпјҢдё”дёҚжңғи®ҠеӢ•)
    static float HalfWidth()  ;
    static float HalfHeight() ;

    // еӢ•ж…Ӣз«ҷз«ӢеҒҸз§»пјҡfloor еҚҠй«ҳ + и§’иүІеҚҠй«ҳ
    static float StandOffset(const std::shared_ptr<Character>& floor) ;

    // зү©зҗҶи§Јжһҗ(privateпјҢз”ұ Update зөұдёҖе‘јеҸ«)
    static void  ResolveVertical(int idx,
                          std::vector<PhysicsAgent>& agents,
                          const std::shared_ptr<Character>& floor);

    static bool  IsBeingPushed(int idx,
                                      const std::vector<PhysicsAgent>& agents,
                                      const std::shared_ptr<Character>& floor) ;

    // еӢ•з•«жұәзӯ–(privateпјҢз”ұ Update зөұдёҖе‘јеҸ«)
    static void  UpdateAnimState(int idx,
                          const std::vector<PhysicsAgent>& agents,
                          bool isPushing) ;
};

#endif // CHARACTER_PHYSICS_SYSTEM_HPP
</file>

