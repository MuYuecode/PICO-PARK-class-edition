void LocalPlayScene::OnExit() {
    LOG_INFO("LocalPlayScene::OnExit");

    // 私有物件直接移除
    m_Ctx.Root.RemoveChild(m_PlayerCountText);
    m_Ctx.Root.RemoveChild(m_NoConfigText);

    // 還原共用物件狀態，再移除（與其他借用場景的慣例一致）
