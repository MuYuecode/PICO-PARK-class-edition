    if (m_BGMs.empty()) return;
    m_BGMs[m_CurrentIndex]->Play(1);
    LOG_INFO("BGM play");
}

void BGMPlayer::Pause() const {
    if (!m_BGMs.empty()) m_BGMs[m_CurrentIndex]->Pause();
}

void BGMPlayer::Resume() const {
    if (!m_BGMs.empty()) m_BGMs[m_CurrentIndex]->Resume();
}

