#ifndef CHARACTER_PHYSICS_SYSTEM_HPP
#define CHARACTER_PHYSICS_SYSTEM_HPP

struct CharacterPhysicsSystem {
    static constexpr float kGravity          = 0.75f;
    static constexpr float kJumpForce        = 11.0f;
