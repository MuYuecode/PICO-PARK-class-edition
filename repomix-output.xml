    m_CancelText->SetPosition({COL_CANCEL_X,  ROW_Y_BTN});
    m_DefaultText->SetPosition({COL_DEFAULT_X, ROW_Y_BTN});
}

// ────────────────────────────────────────────────────────────────────────────
// OnEnter
